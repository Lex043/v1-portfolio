---
const uses = [
    {
        id: 1,
        name: "Chrome",
        use: "Primary web browser",
        site: "https://www.google.com/chrome/",
    },
    {
        id: 2,
        name: "Spotify",
        use: "Music streaming",
        site: "https://www.spotify.com",
    },
    {
        id: 3,
        name: "Visual Studio Code",
        use: "Code editor",
        site: "https://code.visualstudio.com",
    },
    {
        id: 4,
        name: "Postman",
        use: "API testing",
        site: "https://www.postman.com",
    },
    {
        id: 5,
        name: "Figma",
        use: "Design Collaboration",
        site: "https://www.figma.com",
    },
];
---

<script>
    import gsap from "gsap";
    gsap.from("#uses", {
        opacity: 0,
        y: 20,
        duration: 0.3,
        ease: "easeOut",
        delay: 0.5,
    });
</script>

<section id="uses" class="px-6 pb-10 md:px-14 lg:px-24 max-w-4xl mx-auto">
    <h2
        class="text-[var(--heading_1_color)] font-medium text-2xl lg:text-4xl font-serif"
    >
        Uses
    </h2>
    <p class="text-[var(--text-color)] text-base font-serif leading-7 mt-4">
        Stuff I use Daily.
    </p>
    <div class="grid grid-cols-1 gap-3 mt-6">
        {
            uses.map((use) => (
                <div class="flex items-center">
                    <ul class="list-disc relative w-fit pl-4">
                        <li class="under text-[var(--text-color)]">
                            <a
                                href={use.site}
                                target="_blank"
                                rel="noopener noreferrer"
                                aria-label="Go to site"
                            >
                                <span class="under"> {use.name}</span>
                            </a>
                        </li>
                    </ul>
                    <span class="mx-2 text-[var(--text-color)]">-</span>
                    <span class="text-sm text-[var(--text-color)]">
                        {use.use}
                    </span>
                </div>
            ))
        }
    </div>
</section>
